{
  "version": 1,
  "description": "CSS element selectors for Barq Aljanoob browser ad blocking. Add selectors to hideSelectors (visibility:hidden) or removeSelectors (removes from DOM).",
  "hideSelectors": [
    ".adsbygoogle",
    ".ad-banner",
    ".ad-container",
    ".ad-wrapper",
    ".advertisement",
    ".advertisements",
    ".advertising",
    ".sponsored-content",
    ".sponsored-post",
    ".sponsored-widget",
    "[class*='ad-slot']",
    "[class*='ad-unit']",
    "[class*='google-ad']",
    "[id*='google_ads']",
    "[id*='ad-banner']",
    "[id*='ad-container']",
    "[data-ad]",
    "[data-ad-unit]",
    "[data-ad-slot]",
    ".pub_300x250",
    ".pub_300x600",
    ".pub_728x90",
    ".pub_160x600",
    ".widget-area .textwidget > a > img",
    ".sidebar-ad",
    "#sidebar-ad",
    ".footer-ad",
    "#footer-ad",
    ".header-ad",
    "#header-ad",
    ".banner-ad",
    "#banner-ad",
    ".sticky-ad",
    "#sticky-ad",
    ".floating-ad",
    ".leaderboard-ad",
    ".billboard-ad",
    ".skyscraper-ad",
    ".interstitial-ad",
    "[class*='interstitial-wrapper']",
    ".overlay-ad",
    ".modal-ad",
    ".popup-ad",
    "[id*='popup-ad']",
    "[class*='popup-ad']"
  ],
  "removeSelectors": [
    "#adhesion-ad",
    ".adhesion-ad",
    "#sticky-footer-ad",
    ".sticky-footer-ad",
    "#push-notification-overlay",
    ".push-notification-prompt",
    "#cookie-consent-banner",
    ".gdpr-banner",
    "[id*='ad-modal']",
    "[class*='ad-modal']"
  ]
}
